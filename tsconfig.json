{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "noEmit": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*", "tests/**/*.ts", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
