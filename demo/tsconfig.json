{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "vue-nnn-router": ["../src/index.ts"],
      "vue-nnn-router/vite": ["../src/vitePlugin.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "*.ts", "vite.config.ts"],
  "vueCompilerOptions": {
    "skipTemplateCodegen": false
  }
}
